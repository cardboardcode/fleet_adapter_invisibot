<?xml version='1.0' ?>

<launch>
  <!-- Fleet Adapter Parameters -->
  <arg name="config_file" default="/fleet_adapter_invisibot_ws/src/fleet_adapter_invisibot/config.yaml"/>
  <arg name="nav_graph_file" default="/fleet_adapter_invisibot_ws/src/fleet_adapter_invisibot/nav_graph.yaml"/>
  <arg name="server_uri" default="ws://localhost:8000/_internal"/>
  <arg name="use_sim_time" default="true" description="Use the /clock topic for time to sync with simulation"/>

  <!-- Fleet Adapter Invisibot  -->
  <group if="$(var use_sim_time)">
    <node pkg="fleet_adapter_invisibot"
          exec="fleet_adapter"
          args="-c $(var config_file) -n $(var nav_graph_file) -sim"
          output="both">

      <param name="server_uri" value="$(var server_uri)"/>
    </node>
  </group>
  <group unless="$(var use_sim_time)">
    <node pkg="fleet_adapter_invisibot"
          exec="fleet_adapter"
          args="-c $(var config_file) -n $(var nav_graph_file)"
          output="both">

      <param name="server_uri" value="$(var server_uri)"/>
    </node>
  </group>

  <!-- Fleet Adapter Invisibot Ingestor/Dropoff -->
  <!-- <node pkg="fleet_adapter_invisibot" -->
        <!-- exec="ingestor_adapter" -->
        <!-- args="\-\-config_file $(var config_file)" -->
        <!-- output="both"> -->
  <!-- </node> -->

  <!-- Fleet Adapter Invisibot Dispensor/Pickup -->
  <!-- <node pkg="fleet_adapter_invisibot" -->
        <!-- exec="dispenser_adapter" -->
        <!-- args="\-\-config_file $(var config_file)" -->
        <!-- output="both"> -->
  <!-- </node> -->

</launch>

